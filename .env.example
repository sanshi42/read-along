# Read Along local data directory.
# READ_ALONG_HOME=~/.local/share/read-along

# Default local TTS backend.
READ_ALONG_TTS_ENGINE=sherpa_onnx_tts
READ_ALONG_TTS_SHERPA_MODEL_TYPE=kokoro
READ_ALONG_TTS_SHERPA_PROVIDER=cpu
READ_ALONG_TTS_SHERPA_NUM_THREADS=2
READ_ALONG_TTS_SHERPA_SPEED=1.0
READ_ALONG_TTS_SHERPA_SID=0

# Fill these paths after running:
#   uv run read-along tts download-model kokoro
READ_ALONG_TTS_SHERPA_KOKORO_MODEL=
READ_ALONG_TTS_SHERPA_KOKORO_VOICES=
READ_ALONG_TTS_SHERPA_KOKORO_TOKENS=
READ_ALONG_TTS_SHERPA_KOKORO_DATA_DIR=

# OpenAI-compatible TTS example. Online endpoints receive sentence text.
# READ_ALONG_TTS_ENGINE=openai_tts
# READ_ALONG_TTS_OPENAI_BASE_URL=http://127.0.0.1:8880/v1
# READ_ALONG_TTS_OPENAI_API_KEY=not-needed
# READ_ALONG_TTS_OPENAI_MODEL=kokoro
# READ_ALONG_TTS_OPENAI_VOICE=af_sky
# READ_ALONG_TTS_OPENAI_FORMAT=mp3

# Edge TTS.
# READ_ALONG_TTS_ENGINE=edge_tts
# READ_ALONG_TTS_EDGE_VOICE=zh-CN-XiaoxiaoNeural

# Azure Speech.
# READ_ALONG_TTS_ENGINE=azure_tts
# READ_ALONG_TTS_AZURE_KEY=
# READ_ALONG_TTS_AZURE_REGION=eastasia
# READ_ALONG_TTS_AZURE_VOICE=zh-CN-XiaoxiaoNeural

# GPT-SoVITS HTTP API. Text is sent as-is in the `text` query parameter.
# READ_ALONG_TTS_ENGINE=gpt_sovits_tts
# READ_ALONG_TTS_GPT_SOVITS_API_URL=http://127.0.0.1:9880/tts
# READ_ALONG_TTS_GPT_SOVITS_TEXT_LANG=zh
# READ_ALONG_TTS_GPT_SOVITS_REF_AUDIO_PATH=
# READ_ALONG_TTS_GPT_SOVITS_PROMPT_LANG=zh
# READ_ALONG_TTS_GPT_SOVITS_PROMPT_TEXT=
# READ_ALONG_TTS_GPT_SOVITS_MEDIA_TYPE=wav

# Piper local model.
# READ_ALONG_TTS_ENGINE=piper_tts
# READ_ALONG_TTS_PIPER_MODEL_PATH=~/models/piper/zh_CN-huayan-medium.onnx
# READ_ALONG_TTS_PIPER_SPEAKER_ID=0
# READ_ALONG_TTS_PIPER_USE_CUDA=false

# pyttsx3 cross-platform system speech fallback.
# READ_ALONG_TTS_ENGINE=pyttsx3_tts
# READ_ALONG_TTS_PYTTSX3_RATE=180
# READ_ALONG_TTS_PYTTSX3_VOLUME=1.0
# READ_ALONG_TTS_PYTTSX3_VOICE=

# CosyVoice / CosyVoice2 Gradio services.
# READ_ALONG_TTS_ENGINE=cosyvoice_tts
# READ_ALONG_TTS_COSYVOICE_CLIENT_URL=http://127.0.0.1:50000/
# READ_ALONG_TTS_COSYVOICE_SFT=中文女
# READ_ALONG_TTS_ENGINE=cosyvoice2_tts
# READ_ALONG_TTS_COSYVOICE2_CLIENT_URL=http://127.0.0.1:50000/
# READ_ALONG_TTS_COSYVOICE2_SFT=中文女

# Spark Gradio service.
# READ_ALONG_TTS_ENGINE=spark_tts
# READ_ALONG_TTS_SPARK_API_URL=http://127.0.0.1:7860/
# READ_ALONG_TTS_SPARK_API_NAME=voice_clone
# READ_ALONG_TTS_SPARK_PROMPT_WAV_UPLOAD=voice_clone/voice.wav

# X-TTS HTTP API.
# READ_ALONG_TTS_ENGINE=x_tts
# READ_ALONG_TTS_X_TTS_API_URL=http://127.0.0.1:8020/tts_to_audio
# READ_ALONG_TTS_X_TTS_SPEAKER_WAV=female
# READ_ALONG_TTS_X_TTS_LANGUAGE=en

# SiliconFlow API.
# READ_ALONG_TTS_ENGINE=siliconflow_tts
# READ_ALONG_TTS_SILICONFLOW_API_URL=https://api.siliconflow.cn/v1/audio/speech
# READ_ALONG_TTS_SILICONFLOW_API_KEY=
# READ_ALONG_TTS_SILICONFLOW_MODEL=FunAudioLLM/CosyVoice2-0.5B
# READ_ALONG_TTS_SILICONFLOW_VOICE=FunAudioLLM/CosyVoice2-0.5B:alex
# READ_ALONG_TTS_SILICONFLOW_FORMAT=mp3

# MiniMax API.
# READ_ALONG_TTS_ENGINE=minimax_tts
# READ_ALONG_TTS_MINIMAX_GROUP_ID=
# READ_ALONG_TTS_MINIMAX_API_KEY=
# READ_ALONG_TTS_MINIMAX_VOICE_ID=male-qn-qingse

# Fish Audio API.
# READ_ALONG_TTS_ENGINE=fish_api_tts
# READ_ALONG_TTS_FISH_API_KEY=
# READ_ALONG_TTS_FISH_REFERENCE_ID=7f92f8afb8ec43bf81429cc1c9199cb1

# ElevenLabs API.
# READ_ALONG_TTS_ENGINE=elevenlabs_tts
# READ_ALONG_TTS_ELEVENLABS_API_KEY=
# READ_ALONG_TTS_ELEVENLABS_VOICE_ID=
# READ_ALONG_TTS_ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# READ_ALONG_TTS_ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Cartesia API.
# READ_ALONG_TTS_ENGINE=cartesia_tts
# READ_ALONG_TTS_CARTESIA_API_KEY=
# READ_ALONG_TTS_CARTESIA_VOICE_ID=6ccbfb76-1fc6-48f7-b71d-91ac6298247b
# READ_ALONG_TTS_CARTESIA_MODEL_ID=sonic-3
# READ_ALONG_TTS_CARTESIA_FORMAT=wav

# Local model backends. These are heavy and may need model-specific setup.
# READ_ALONG_TTS_ENGINE=bark_tts
# READ_ALONG_TTS_BARK_VOICE=v2/en_speaker_1
# READ_ALONG_TTS_ENGINE=coqui_tts
# READ_ALONG_TTS_COQUI_MODEL_NAME=
# READ_ALONG_TTS_COQUI_SPEAKER_WAV=
# READ_ALONG_TTS_COQUI_LANGUAGE=en
# READ_ALONG_TTS_COQUI_DEVICE=cpu
# READ_ALONG_TTS_ENGINE=melo_tts
# READ_ALONG_TTS_MELO_LANGUAGE=EN
# READ_ALONG_TTS_MELO_SPEAKER=EN-Default
# READ_ALONG_TTS_MELO_DEVICE=auto
